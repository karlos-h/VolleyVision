// VolleyVision — Prisma Schema
// Phase 1: Match Tracking System
//
// Architectural decisions:
// - Events table is intentionally simple (no score state, no rotation) so Phase 1
//   stays lean, but includes set_number and rally_number to unlock Phase 3 heat maps.
// - Player positions stored as enum so future dashboards can filter by role.
// - Match stores home_score/away_score per set as JSON to avoid a separate SetScore
//   table in Phase 1, while still being queryable in Phase 2+.
// - All timestamps use @default(now()) and @updatedAt so audit trails work for free.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

// Phase 7 Sprint 0 — onboarding hint only; never used for permission checks.
enum SignupIntent {
  COACH
  PLAYER
  UNSURE
}

enum Position {
  SETTER
  OUTSIDE_HITTER
  OPPOSITE
  MIDDLE_BLOCKER
  LIBERO
  DEFENSIVE_SPECIALIST
}

enum EventType {
  // Attacking
  KILL
  ATTACK_ERROR
  ATTACK_ATTEMPT
  TIP        // non-scoring tip over the block; a winning tip is recorded as KILL
  FREE_BALL  // ball sent over on a free pass; counts as an attack attempt

  // Serving
  ACE
  SERVICE_ERROR
  SERVE_IN

  // Passing
  PASS_3
  PASS_2
  PASS_1
  PASS_0

  // Blocking
  SOLO_BLOCK
  BLOCK_ASSIST
  BLOCK_ERROR

  // Defence
  DIG
  DIG_ERROR

  // Setting
  ASSIST
  SETTING_ERROR
}

enum MatchStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum UserRole {
  ADMIN
  COACH
  PLAYER
  VIEWER
}

// Phase 5 Sprint 3 — Team Membership
enum TeamRole {
  HEAD_COACH
  // Iteration 3 — head-coach-equivalent authority, minus TRANSFER_OWNERSHIP
  // (ownership transfer stays owner-only). Also an approval authority.
  MANAGER
  ASSISTANT_COACH
  STATISTICIAN
  PLAYER
  VIEWER
}

// Iteration 3 — per-member access tier for the three tiered mutation
// categories (roster / invitations / match management). Overrides the static
// role-permission check for those categories only:
//   VIEW_ONLY         → cannot perform the action at all (403), even if the role would allow it
//   APPROVAL_REQUIRED → action is queued as a pending ApprovalRequest
//   FULL_ACCESS       → action applies immediately
// Live match tracking (TRACK_MATCH) is intentionally NOT tiered — it stays a
// real-time, role-based yes/no.
enum AccessTier {
  VIEW_ONLY
  APPROVAL_REQUIRED
  FULL_ACCESS
}

// Phase 5 Sprint 4 — Team Invitations
enum InvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
}

// ─── Team Chat (FOUNDATION) ───────────────────────────────────────────────────
//
// FOUNDATION ONLY (2026-07). One shared TEAM channel per team; text + image/file
// attachments; polled (no realtime yet). Schema is deliberately shaped so the
// later work — direct messages, multiple channels, reactions, threads — is
// additive, not a rewrite:
//   - Channel.type distinguishes TEAM from a future DIRECT channel.
//   - ChannelMember exists so DMs/private channels have an explicit membership
//     list; for a TEAM channel, membership is implicit (= TeamMembership) and
//     ChannelMember rows are NOT created. Read code must treat "TEAM channel +
//     caller is a team member" as authorized without needing a ChannelMember row.
//   - Messages are SOFT-deleted (deletedAt) — never hard-deleted — so moderation
//     leaves an audit trail and the timeline stays stable.

enum ChannelType {
  TEAM     // the single shared team channel (foundation)
  DIRECT   // reserved: 1:1 / small-group DM (not built yet)
}

enum AttachmentKind {
  IMAGE    // jpg/png/webp/gif — gets a thumbnail
  FILE     // pdf/doc/etc. — generic, no thumbnail
}

// ─── Feedback (2026-07) ─────────────────────────────────────────────────────────
// In-app bug reports / feature requests. Any user submits; only the global
// ADMIN triages. Attachments reuse AttachmentKind + the chat Supabase bucket
// (feedbackStorage.service.ts) under a `feedback/` key prefix.

enum FeedbackType {
  BUG
  FEATURE_REQUEST
  GENERAL
}

enum FeedbackSeverity {
  LOW
  MEDIUM
  HIGH
}

enum FeedbackStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  WONT_FIX
}

// Stabilization Pass 2 — Head-coach approval queue
enum ApprovalAction {
  PLAYER_CREATE
  PLAYER_UPDATE
  PLAYER_DELETE
  MATCH_CREATE
  MATCH_UPDATE
  MATCH_DELETE
  INVITATION_CREATE
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

// ─── Models ───────────────────────────────────────────────────────────────────

// Phase 5 Sprint 1 — Authentication
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  firstName    String   @map("first_name")
  lastName     String   @map("last_name")
  role         UserRole @default(COACH)

  // Phase 7 Sprint 0 — one-time onboarding hint, null for all pre-existing users.
  // NEVER used in permission checks — all permissions derive from TeamMembership role.
  signupIntent SignupIntent? @map("signup_intent")

  profileImage String?  @map("profile_image")

  // Iteration 3 — the athlete's own stated position preference, independent of
  // the roster position a coach assigns them (Player.position) on any team.
  preferredPosition Position? @map("preferred_position")

  // Phase 5 Sprint 2 — Team Ownership
  teams        Team[]

  // Iteration 3 — Training sessions this user created (staff only).
  createdTrainingSessions TrainingSession[]

  // Phase 5 Sprint 3 — Team Memberships
  memberships  TeamMembership[]

  // Phase 7 Sprint 1 — League Intelligence
  createdLeagues League[]

  // Phase 5 Sprint 4 — Invitations
  sentInvitations Invitation[]

  // Stabilization Pass 2 — Approval queue
  requestedApprovals ApprovalRequest[] @relation("ApprovalRequester")
  resolvedApprovals  ApprovalRequest[] @relation("ApprovalResolver")

  // Phase 5 Sprint 5 — Profile
  bio          String?
  phoneNumber  String?  @map("phone_number")
  dateOfBirth  DateTime? @map("date_of_birth")
  city         String?
  country      String?

  // Stabilization — physical profile (optional, profile-level not per-team)
  heightCm     Int?     @map("height_cm")
  weightKg     Int?     @map("weight_kg")

  // Phase 5 Sprint 5 — Player link
  playerRecords Player[]

  // Team Chat foundation
  sentMessages   Message[]       @relation("MessageSender")
  channelMembers ChannelMember[]

  // Feedback tab
  feedback     Feedback[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("users")
}

model Team {
  id        String   @id @default(cuid())
  name      String
  division  String?
  season    String

  // Every team has an owner, set at creation. A team is visible only to its
  // owner, its accepted members, or a global ADMIN — there is no public team.
  ownerId   String   @map("owner_id")
  owner     User     @relation(fields: [ownerId], references: [id])

  // Iteration 3 — the team's current league season (nullable). Set from the
  // team create/edit form; new matches default their competition from it. Kept
  // in sync with a LeagueTeam join row so League Hub sees the same association.
  leagueSeasonId String?       @map("league_season_id")
  leagueSeason   LeagueSeason? @relation("TeamCurrentSeason", fields: [leagueSeasonId], references: [id], onDelete: SetNull)

  players     Player[]
  matches     Match[]

  // Iteration 3 — Training sessions
  trainingSessions TrainingSession[]

  // Phase 5 Sprint 3 — Team Memberships
  memberships TeamMembership[]

  // Phase 7 — multi-team player links
  playerLinks PlayerTeamLink[]

  // Phase 7 Sprint 1 — League Intelligence
  leagueTeams LeagueTeam[]

  // Phase 5 Sprint 4 — Invitations
  invitations Invitation[]

  // Stabilization Pass 2 — Approval queue
  approvalRequests ApprovalRequest[]

  // Team Chat foundation
  channels    Channel[]

  // Team join codes — persistent, reusable, self-serve. Player code joins as
  // PLAYER instantly; staff code lets the redeemer pick a staff role. Distinct
  // from per-email Invitations (single-use, email-locked, expiring).
  playerJoinCode String? @unique @map("player_join_code")
  staffJoinCode  String? @unique @map("staff_join_code")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("teams")
}

// Phase 5 Sprint 3 — Team Membership join table
model TeamMembership {
  id       String   @id @default(cuid())

  userId   String   @map("user_id")
  teamId   String   @map("team_id")
  role     TeamRole

  // Iteration 3 — per-member access tiers. Seeded from the role at creation
  // (see defaultAccessTiers), then independently overridable by a coach.
  // These supersede the role-permission check for their category.
  rosterAccess     AccessTier @default(APPROVAL_REQUIRED) @map("roster_access")
  invitationAccess AccessTier @default(APPROVAL_REQUIRED) @map("invitation_access")
  matchAccess      AccessTier @default(APPROVAL_REQUIRED) @map("match_access")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  team     Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  joinedAt DateTime @default(now()) @map("joined_at")

  @@unique([userId, teamId])
  @@index([teamId])
  @@index([userId])

  @@map("team_memberships")
}

// Phase 5 Sprint 6 — Audit Log
model AuditLog {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  action     String
  resource   String
  resourceId String?  @map("resource_id")
  meta       Json?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([resource, resourceId])
  @@index([createdAt])

  @@map("audit_logs")
}

// Phase 5 Sprint 4 — Team Invitation System
model Invitation {
  id          String           @id @default(cuid())
  email       String
  teamId      String           @map("team_id")
  invitedById String           @map("invited_by_id")
  role        TeamRole
  status      InvitationStatus @default(PENDING)
  token       String           @unique

  // Stabilization Pass 2 — short human-enterable code for the email flow.
  // Nullable so pre-existing invitations remain valid (they use `token`).
  joinCode    String?          @unique @map("join_code")

  expiresAt   DateTime         @map("expires_at")
  acceptedAt  DateTime?        @map("accepted_at")

  team        Team             @relation(fields: [teamId], references: [id], onDelete: Cascade)
  invitedBy   User             @relation(fields: [invitedById], references: [id], onDelete: Cascade)

  createdAt   DateTime         @default(now())

  @@index([teamId])
  @@index([invitedById])
  @@index([token])
  @@index([email])

  @@map("invitations")
}

// Stabilization Pass 2 — Head-coach approval queue
// Structural team changes (player/match CRUD, invitations) attempted by a
// non-head-coach are recorded here as PENDING instead of applied immediately.
// The head coach/owner approves (applies the change) or rejects. Live
// match-tracking actions are intentionally NOT routed through this system.
model ApprovalRequest {
  id            String         @id @default(cuid())
  teamId        String         @map("team_id")
  team          Team           @relation(fields: [teamId], references: [id], onDelete: Cascade)

  requestedById String         @map("requested_by_id")
  requestedBy   User           @relation("ApprovalRequester", fields: [requestedById], references: [id], onDelete: Cascade)

  action        ApprovalAction
  // The create/update/delete data needed to apply the change once approved.
  payload       Json
  // playerId/matchId for update/delete actions; null for create.
  targetId      String?        @map("target_id")

  status        ApprovalStatus @default(PENDING)
  resolvedById  String?        @map("resolved_by_id")
  resolvedBy    User?          @relation("ApprovalResolver", fields: [resolvedById], references: [id], onDelete: SetNull)
  resolvedAt    DateTime?      @map("resolved_at")

  createdAt     DateTime       @default(now())

  @@index([teamId, status])
  @@map("approval_requests")
}

model Player {
  id           String   @id @default(cuid())
  firstName    String   @map("first_name")
  lastName     String   @map("last_name")
  jerseyNumber Int      @map("jersey_number")
  position     Position

  team         Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  teamId       String   @map("team_id")

  // Phase 5 Sprint 5 — link player record to user account (nullable, non-destructive)
  userId       String?  @map("user_id")
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  events       Event[]

  // Phase 7 — additional team links (does not replace teamId)
  teamLinks    PlayerTeamLink[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([teamId, jerseyNumber])
  @@index([userId])
  @@map("players")
}

// Phase 7 — Player multi-team join table
// Records extra teams a player is explicitly linked to, beyond their primary teamId.
// No backfill needed: the existing teamId already represents the home team.
model PlayerTeamLink {
  id        String   @id @default(cuid())

  playerId  String   @map("player_id")
  teamId    String   @map("team_id")

  player    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([playerId, teamId])
  @@index([playerId])
  @@index([teamId])

  @@map("player_team_links")
}

model Match {
  id          String      @id @default(cuid())
  matchDate   DateTime    @map("match_date")
  opponent    String
  competition String?
  venue       String?
  status      MatchStatus @default(SCHEDULED)

  // Stores per-set scores: [{ set: 1, home: 25, away: 23 }, ...]
  // Kept as JSON in Phase 1 for speed; easy to normalise in Phase 2.
  setScores    Json?       @map("set_scores")

  // Phase 4 Sprint 1 — Live Scoring Engine
  homeScore    Int         @default(0) @map("home_score")    // current set running score
  awayScore    Int         @default(0) @map("away_score")    // current set running score
  homeSetsWon  Int         @default(0) @map("home_sets_won")
  awaySetsWon  Int         @default(0) @map("away_sets_won")

  // Set to true by a manual set operation (End Set / Undo Set / Reset Match).
  // Those declare set boundaries that the event timeline cannot reproduce, so
  // once set, recalculateMatchState stops rebuilding set state from a replay —
  // otherwise the next Undo Event would silently erase the override. See
  // services/matchState.service.ts.
  manualScoreOverride Boolean @default(false) @map("manual_score_override")

  team        Team        @relation(fields: [teamId], references: [id], onDelete: Cascade)
  teamId      String      @map("team_id")

  events      Event[]
  videos      Video[]
  scoreAdjustments ScoreAdjustment[]

  // Phase 7 Sprint 1 — League Intelligence (nullable FKs on LeagueMatch, set by each side)
  homeLeagueMatches LeagueMatch[] @relation("LeagueMatchHome")
  awayLeagueMatches LeagueMatch[] @relation("LeagueMatchAway")

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@map("matches")
}

// Stabilization — manual score corrections recorded as deltas so that
// recalculateMatchState can replay them alongside events. Without this,
// any undo/delete wiped manual adjustments (it replayed events only).
model ScoreAdjustment {
  id        String   @id @default(cuid())
  matchId   String   @map("match_id")
  homeDelta Int      @map("home_delta")
  awayDelta Int      @map("away_delta")
  setNumber Int      @map("set_number")

  // True when checkSetCompletion completed a set as a direct result of this
  // adjustment, recorded at creation time because it cannot be inferred later:
  // completion zeroes the running score, so undoing against the current score
  // has lost the baseline it needs. See lib/undo.ts reverseCompletingAction.
  completedSet Boolean @default(false) @map("completed_set")

  createdAt DateTime @default(now())

  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@index([matchId])
  @@map("score_adjustments")
}

// Phase 7 — Video upload & timestamp tagging
model Video {
  id               String           @id @default(cuid())
  matchId          String           @map("match_id")
  filename         String
  filePath         String           @map("file_path")
  mimeType         String           @map("mime_type")
  uploadedAt       DateTime         @default(now()) @map("uploaded_at")
  uploadedByUserId String           @map("uploaded_by_user_id")

  match            Match            @relation(fields: [matchId], references: [id], onDelete: Cascade)
  timestamps       VideoTimestamp[]

  @@index([matchId])
  @@map("videos")
}

model VideoTimestamp {
  id               String  @id @default(cuid())
  videoId          String  @map("video_id")
  timestampSeconds Int     @map("timestamp_seconds")
  label            String
  eventId          String? @map("event_id")

  video            Video   @relation(fields: [videoId], references: [id], onDelete: Cascade)
  event            Event?  @relation(fields: [eventId], references: [id], onDelete: SetNull)

  @@index([videoId])
  @@map("video_timestamps")
}

// Event is the central fact table. Every analytics calculation in Phases 2–5
// aggregates from this table, so the schema must be both minimal (fast to write
// courtside) and rich enough to slice by player, match, set, and event type.
model Event {
  id          String    @id @default(cuid())

  eventType   EventType @map("event_type")
  setNumber   Int       @map("set_number")             // 1–5
  rallyNumber Int?      @map("rally_number")           // optional; enables Phase 3 patterns
  courtZone      Int?      @map("court_zone")             // 1–6 standard volleyball zones
  rotationNumber Int?      @map("rotation_number")        // 1–6 volleyball rotations (Phase 4)
  notes          String?                                   // optional coach annotation

  // Iteration 3 — an Event belongs to EITHER a match OR a training session.
  // matchId is now nullable; training events set trainingSessionId instead.
  // Every existing stats query filters by a match context (or spreads
  // ownEventsOnly, which now excludes training), so training events never leak
  // into match/career analytics.
  match       Match?    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  matchId     String?   @map("match_id")

  trainingSession   TrainingSession? @relation(fields: [trainingSessionId], references: [id], onDelete: Cascade)
  trainingSessionId String?          @map("training_session_id")

  // playerId is optional as of Phase 6 Sprint 3 to support opponent event recording.
  // Existing rows all have a playerId; new opponent events (isOpponentEvent=true) omit it.
  player      Player?   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  playerId    String?   @map("player_id")

  // Phase 6 Sprint 3 — opponent scouting fields
  isOpponentEvent    Boolean @default(false) @map("is_opponent_event")
  opponentJerseyNumber Int?  @map("opponent_jersey_number")

  // True when checkSetCompletion completed a set as a direct result of this
  // event. Only consulted when the match is under manualScoreOverride, where
  // undo can't replay the timeline and reverses this event directly instead —
  // the same lost-baseline problem as ScoreAdjustment.completedSet.
  completedSet Boolean @default(false) @map("completed_set")

  videoTimestamps VideoTimestamp[]

  recordedAt  DateTime  @default(now()) @db.Timestamptz(3) @map("recorded_at")

  // Indexes support the most common Phase 2 query patterns:
  //   - "all events for player X in match Y"
  //   - "all kills in set 3"
  //   - "timeline of events ordered by time"
  @@index([matchId])
  @@index([playerId])
  @@index([matchId, setNumber])
  @@index([playerId, eventType])
  @@index([matchId, courtZone])
  @@index([matchId, rotationNumber])
  @@index([trainingSessionId])
  @@index([recordedAt])

  @@map("events")
}

// ─── Team Chat (FOUNDATION) — models ────────────────────────────────────────────

model Channel {
  id        String      @id @default(cuid())
  type      ChannelType @default(TEAM)

  // TEAM channels belong to exactly one team. (A future DIRECT channel may set
  // teamId when scoped to a team, or leave conventions to the DM work.)
  teamId    String      @map("team_id")
  team      Team        @relation(fields: [teamId], references: [id], onDelete: Cascade)

  name      String?     // null for the implicit team channel; used once multiple channels exist

  messages  Message[]
  members   ChannelMember[]  // unused for TEAM channels (implicit membership)

  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  // One TEAM channel per team. NOTE: this also means at most one DIRECT channel
  // per (teamId, type) — the DM work will need a different uniqueness strategy
  // (e.g. keyed by member pair) and should replace this constraint then.
  @@unique([teamId, type])
  @@index([teamId])
  @@map("channels")
}

// Reserved for DIRECT channels / private sub-channels. NOT populated for the
// foundation's TEAM channel — do not require a row here to authorize team chat.
model ChannelMember {
  id        String   @id @default(cuid())
  channelId String   @map("channel_id")
  userId    String   @map("user_id")

  channel   Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Reserved for future unread badges — updated when the user opens the channel.
  lastReadAt DateTime? @map("last_read_at")

  joinedAt  DateTime @default(now()) @map("joined_at")

  @@unique([channelId, userId])
  @@index([userId])
  @@map("channel_members")
}

model Message {
  id        String   @id @default(cuid())
  channelId String   @map("channel_id")
  channel   Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)

  // Author. Kept even if the user later leaves the team (SetNull) so history is
  // preserved; render as "former member" when null.
  senderId  String?  @map("sender_id")
  sender    User?    @relation("MessageSender", fields: [senderId], references: [id], onDelete: SetNull)

  // Body is nullable so an attachment-only message is valid. API must reject a
  // message that has neither body text nor at least one attachment.
  body      String?

  attachments MessageAttachment[]

  // Edit + soft-delete audit trail.
  editedAt        DateTime? @map("edited_at")
  deletedAt       DateTime? @map("deleted_at")
  deletedByUserId String?   @map("deleted_by_user_id")  // author OR a moderator

  // Duplicate-send protection (slice 5). The client mints a key per composed
  // message and reuses it on retry; a resend with a known key returns the
  // existing message instead of creating a duplicate. Null for non-idempotent
  // sends (nulls don't collide in the unique index).
  clientKey String? @map("client_key")

  createdAt DateTime @default(now())

  // Timeline + pagination: order by (createdAt, id). createdAt is server-set
  // (default now()), so it is monotonic per server; id breaks ties. If a future
  // phase needs a strict total order under heavy concurrent writes, add an
  // autoincrement seq column and paginate on that instead.
  @@unique([channelId, clientKey])
  @@index([channelId, createdAt])
  @@map("messages")
}

model MessageAttachment {
  id        String         @id @default(cuid())
  messageId String         @map("message_id")
  message   Message        @relation(fields: [messageId], references: [id], onDelete: Cascade)

  kind      AttachmentKind

  // Supabase Storage object path (NOT a public URL). Signed URLs are minted on
  // read. Mirrors the existing Video model's filePath/mimeType convention.
  storagePath String       @map("storage_path")
  fileName    String       @map("file_name")   // original filename for display/download
  mimeType    String       @map("mime_type")
  sizeBytes   Int          @map("size_bytes")

  // Populated for IMAGE only.
  width       Int?
  height      Int?

  uploadedByUserId String   @map("uploaded_by_user_id")

  createdAt DateTime @default(now())

  @@index([messageId])
  @@map("message_attachments")
}

// ─── Iteration 3 — Training sessions (foundation only) ─────────────────────────
//
// FOUNDATION ONLY (2026-07). Schema + minimal staff-only CRUD (create/list per
// team). NOT YET BUILT — the next pass should add: a recording UI (reusing the
// Event model with trainingSessionId set), a training-progress view for players,
// and the data behind Task 4's "Training load" KPI card and "Plan session" CTA
// on the coach dashboard (both omitted/stubbed until real sessions exist).
//
// ISOLATION: training Events (matchId = null, trainingSessionId set) must never
// appear in match/career/team analytics. This is enforced by `ownEventsOnly`
// (lib/eventFilters.ts) which excludes trainingSessionId != null, plus the fact
// that every match-scoped query constrains matchId. Do not add a stats query
// that reads Events by player without spreading ownEventsOnly.
model TrainingSession {
  id              String   @id @default(cuid())

  teamId          String   @map("team_id")
  team            Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  sessionDate     DateTime @map("session_date")
  durationMinutes Int?     @map("duration_minutes")
  location        String?
  notes           String?

  createdByUserId String   @map("created_by_user_id")
  createdBy       User     @relation(fields: [createdByUserId], references: [id])

  events          Event[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([teamId])
  @@map("training_sessions")
}

// ─── Feedback tab (2026-07) ─────────────────────────────────────────────────────

model Feedback {
  id          String            @id @default(cuid())
  userId      String            @map("user_id")
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  type        FeedbackType
  // Only meaningful for BUG — null for feature requests / general feedback.
  severity    FeedbackSeverity?
  subject     String
  description String

  status      FeedbackStatus    @default(OPEN)
  adminNotes  String?           @map("admin_notes")

  // Route the user was on when they submitted — cheap debugging context.
  pageContext String?           @map("page_context")

  attachments FeedbackAttachment[]

  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([userId])
  @@index([status])
  @@map("feedback")
}

model FeedbackAttachment {
  id           String         @id @default(cuid())
  feedbackId   String         @map("feedback_id")
  feedback     Feedback       @relation(fields: [feedbackId], references: [id], onDelete: Cascade)

  kind         AttachmentKind

  // Supabase Storage object path (NOT a public URL) — same contract as
  // MessageAttachment.storagePath; signed URLs are minted on read.
  storagePath  String         @map("storage_path")
  originalName String         @map("original_name")
  mimeType     String         @map("mime_type")
  sizeBytes    Int            @map("size_bytes")

  // Populated for IMAGE only.
  width        Int?
  height       Int?

  createdAt    DateTime       @default(now())

  @@index([feedbackId])
  @@map("feedback_attachments")
}

// ─── Phase 7 Sprint 1 — League Intelligence ───────────────────────────────────

// A League is a competition container (e.g. "Regional Volleyball Association").
// Only ADMIN users can create leagues; coaches join via LeagueTeam.
model League {
  id              String         @id @default(cuid())
  name            String
  division        String?

  createdByUserId String         @map("created_by_user_id")
  createdBy       User           @relation(fields: [createdByUserId], references: [id])

  seasons         LeagueSeason[]

  createdAt       DateTime       @default(now())

  @@index([createdByUserId])
  @@map("leagues")
}

// A single season within a league (e.g. "2026 Winter").
model LeagueSeason {
  id        String        @id @default(cuid())
  leagueId  String        @map("league_id")
  league    League        @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  name      String
  startDate DateTime      @map("start_date")
  endDate   DateTime?     @map("end_date")

  teams     LeagueTeam[]
  fixtures  LeagueMatch[]

  // Iteration 3 — teams that point at this season as their current league
  // (Team.leagueSeasonId). Distinct from `teams` (the LeagueTeam join used by
  // fixtures/standings); this is the lightweight "current league" pointer.
  currentTeams Team[]     @relation("TeamCurrentSeason")

  createdAt DateTime      @default(now())

  @@index([leagueId])
  @@map("league_seasons")
}

// Links an independently-owned Team into a LeagueSeason.
// MANAGE_TEAM on the target team is required to create this link.
model LeagueTeam {
  id             String        @id @default(cuid())
  leagueSeasonId String        @map("league_season_id")
  leagueSeason   LeagueSeason  @relation(fields: [leagueSeasonId], references: [id], onDelete: Cascade)

  teamId         String        @map("team_id")
  team           Team          @relation(fields: [teamId], references: [id], onDelete: Cascade)

  joinedAt       DateTime      @default(now()) @map("joined_at")

  homeFixtures   LeagueMatch[] @relation("HomeLeagueTeam")
  awayFixtures   LeagueMatch[] @relation("AwayLeagueTeam")

  @@unique([leagueSeasonId, teamId])
  @@index([teamId])
  @@map("league_teams")
}

// A scheduled fixture between two LeagueTeams.
// homeMatchId / awayMatchId are set independently by each team's coach — each side links
// their own already-owned Match record. Either or both may be null until linked.
model LeagueMatch {
  id             String       @id @default(cuid())
  leagueSeasonId String       @map("league_season_id")
  leagueSeason   LeagueSeason @relation(fields: [leagueSeasonId], references: [id], onDelete: Cascade)

  homeLeagueTeamId String     @map("home_league_team_id")
  homeLeagueTeam   LeagueTeam @relation("HomeLeagueTeam", fields: [homeLeagueTeamId], references: [id])

  awayLeagueTeamId String     @map("away_league_team_id")
  awayLeagueTeam   LeagueTeam @relation("AwayLeagueTeam", fields: [awayLeagueTeamId], references: [id])

  scheduledDate    DateTime   @map("scheduled_date")

  // Each side links their own Match independently. Null = not yet linked.
  homeMatchId      String?    @map("home_match_id")
  homeMatch        Match?     @relation("LeagueMatchHome", fields: [homeMatchId], references: [id], onDelete: SetNull)

  awayMatchId      String?    @map("away_match_id")
  awayMatch        Match?     @relation("LeagueMatchAway", fields: [awayMatchId], references: [id], onDelete: SetNull)

  createdAt        DateTime   @default(now())

  @@index([leagueSeasonId])
  @@index([homeLeagueTeamId])
  @@index([awayLeagueTeamId])
  @@map("league_matches")
}
