DATABASE_URL="postgresql://postgres:password@localhost:5432/volleyvision"
PORT=3001
NODE_ENV=development
CLIENT_URL=http://localhost:5173
# Phase 6 Sprint 0 — AI Match Summary (required for narrative endpoint)
ANTHROPIC_API_KEY=

# Pre-fills the Public/Private toggle on the create-team form; the coach can
# still change it before submitting. The DB column default stays `true` so
# existing rows are unaffected.
# IMPORTANT: flip this to `private` before any real/production deployment.

# Stabilization Pass 2 — Invitation email (Gmail SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=himextradingltd@gmail.com
# TODO: generate a Gmail App Password (requires 2FA enabled on the account) at
# Google Account → Security → App Passwords, then paste it here.
SMTP_PASS=

# Team Chat attachments — Supabase Storage (object store ONLY; app DB stays local Postgres)
# Service-role key is server-only. NEVER commit or log it.
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_CHAT_BUCKET=team-chat
